{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/renewal-notify",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/renewal-charge",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/menu-select-notify",
      "schedule": "0 9 * * *"
    }
  ]
}
